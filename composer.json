{
    "name": "bpjs/bpjs",
    "description": "Sebuah Framework untuk PHP",
    "type": "project",
    "require": {
        "php" : "^8.1",
        "firebase/php-jwt": "^6.10",
        "fadli-dev/wilayah-id": "^1.0",
        "bpjs/framework": "^2.2",
        "spiral/roadrunner": "^2025.1",
        "nyholm/psr7": "^1.8",
        "spiral/roadrunner-http": "^4.1"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "config/",
            "Middlewares\\":"app/Middleware/"
        }
    },
    "authors": [
        {
            "name": "Fadli Azka Prayogi",
            "email": "fadliazkaprayogi1@gmail.com"
        }
    ],
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php bpjs init",
            "@php bpjs generate:key"
        ]
    },
    "minimum-stability": "stable"
}
